---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import JourneyStep from "../components/JourneyStep.astro";
import QuestionMark from "../icons/QuestionMark.astro";
import MapPin from "../icons/MapPin.astro";
import Phone from "../icons/Phone.astro";
import Mail from "../icons/Mail.astro";

const cats = [
  {
    name: "Pixel",
    image: "/cat_1.png",
    age: "2 YEARS",
    temperament: "PLAYFUL",
    status: "NEW ARRIVAL",
  },
  {
    name: "Glitch",
    image: "/cat_2.png",
    age: "4 MONTHS",
    temperament: "CUDDLY",
    status: "",
  },
  {
    name: "Sprite",
    image: "/cat_3.png",
    age: "5 YEARS",
    temperament: "CALM",
    status: "ADOPTED",
  },
];
---

<Layout>
  <!-- Hero Section -->
  <section
    class="w-full min-h-[670px] flex justify-center items-center py-24 px-6 lg:px-24 bg-surface"
  >
    <div
      class="w-full max-w-[1232px] flex flex-col lg:flex-row items-center justify-between gap-12 relative"
    >
      <!-- Left Column: Text & CTA -->
      <div
        class="flex flex-col items-start gap-6 max-w-[592px] w-full shrink-0 lg:w-[48%] relative z-10 mt-12 lg:mt-0"
      >
        <!-- Badge -->
        <div class="flex flex-row items-start py-1 px-3 bg-tertiary-fixed">
          <span
            class="font-pixel text-[10px] uppercase text-on-surface tracking-[-0.25px] leading-[15px]"
          >
            New Game + New Companion
          </span>
        </div>

        <!-- Heading -->
        <h1
          class="font-display font-bold text-6xl md:text-[96px] leading-none uppercase tracking-[-4.8px] text-on-surface w-full"
        >
          Find Your Purr-fect Pixel Mate
        </h1>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-2 w-full mt-2">
          <Button label="START QUEST" variant="primary" />
          <Button label="LEARN MORE" variant="secondary" />
        </div>
      </div>

      <!-- Right Column: Image & Feature Card -->
      <div
        class="relative w-full max-w-[592px] h-[400px] md:h-[600px] shrink-0 mt-8 lg:mt-0"
      >
        <!-- Decorative Background Box -->
        <div
          class="absolute w-40 h-40 bg-tertiary-fixed/50 -top-10 -right-10 z-0 hidden md:block"
        >
        </div>

        <!-- Image Container -->
        <div class="w-full h-full relative z-10 bg-surface-container">
          <img
            src="/hero_cat.png"
            alt="Portrait of a beautiful fluffy cat"
            class="w-full h-full object-cover grayscale-20"
          />
        </div>

        <!-- Floating Card -->
        <div
          class="absolute -left-6 -bottom-6 w-[225px] h-[100px] bg-surface-container-lowest p-6 flex flex-col justify-center gap-2 z-20 shadow-[6px_6px_0px_rgba(69,85,101,0.2)]"
        >
          <span
            class="font-pixel text-[8px] uppercase text-primary leading-[12px]"
          >
            Latest Arrival
          </span>
          <span
            class="font-display font-black text-2xl uppercase text-on-surface leading-[32px] tracking-[-1.2px]"
          >
            Meet Pixel
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Cats Grid Section -->
  <section
    class="w-full py-32 px-8 md:px-16 bg-surface-container-low"
    id="adopt"
  >
    <div class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8"
      >
        <div class="flex flex-col gap-4">
          <span
            class="font-pixel text-primary text-xs uppercase tracking-widest"
            >Select Character</span
          >
          <h2
            class="font-display text-4xl md:text-5xl font-bold text-on-surface uppercase"
          >
            Available Cats
          </h2>
        </div>
        <Button label="VIEW ALL" variant="primary" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16">
        {cats.map((cat) => <Card cat={cat} />)}
      </div>
    </div>
  </section>

  <!-- The Journey To Home -->
  <section
    class="w-full py-32 px-8 md:px-16 bg-surface flex justify-center"
    id="process"
  >
    <div
      class="max-w-7xl w-full flex flex-col lg:flex-row gap-16 lg:gap-24 relative"
    >
      <!-- Left Column -->
      <div class="w-full lg:w-[368px] flex flex-col shrink-0 z-10">
        <div class="flex flex-col gap-4">
          <span
            class="font-pixel text-[10px] text-primary uppercase tracking-widest"
          >
            System Logic
          </span>
          <h2
            class="font-display text-4xl md:text-5xl font-bold text-on-surface uppercase tracking-tight leading-none mb-4"
          >
            The Journey<br />To Home
          </h2>
          <p class="font-body text-lg text-on-surface-variant leading-relaxed">
            Adopting a cat from Kitt8-Bit is a linear journey designed to ensure
            a lifelong match. We prioritize character compatibility over pixels.
          </p>
        </div>

        <!-- Decorative Image/Icon Box -->
        <div
          class="w-full h-48 bg-primary-container relative mt-12 hidden md:block"
        >
          <QuestionMark class="absolute top-8 left-8" />

          <div
            class="absolute top-24 left-8 text-surface font-display font-bold text-sm tracking-widest uppercase"
          >
            Quest Log
          </div>
          <div
            class="absolute top-32 left-8 text-surface/80 font-body text-sm max-w-[240px]"
          >
            Follow the steps to unlock your new companion.
          </div>
        </div>
      </div>

      <!-- Right Column -->
      <div
        class="grow flex flex-col bg-surface-container-low border-x-4 border-surface-container-low gap-1"
      >
        <JourneyStep
          number="1"
          title="Application"
          description="Submit your player profile. We want to know about your home base, lifestyle, and what kind of companion you're looking for."
        />
        <JourneyStep
          number="2"
          title="Interview"
          description="A quick sync with our matching specialists to discuss your application and ensure we align on the main quest objectives."
        />
        <JourneyStep
          number="3"
          title="Meet & Greet"
          description="Visit the gallery to interact with your potential matches. Character compatibility is assessed in real-time."
        />
        <JourneyStep
          number="4"
          title="Home Check"
          description="A brief virtual or in-person tour of your environment to verify it's safe and optimized for your new player two."
        />
        <JourneyStep
          number="5"
          title="Final Match"
          description="Sign the adoption papers, obtain your starter item kit, and take your new best friend home."
        />
      </div>
    </div>
  </section>

  <!-- Contact & Shelter -->
  <section
    class="w-full py-32 px-6 md:px-16 flex justify-center bg-surface-container-low"
    id="contact"
  >
    <div
      class="max-w-[1232px] w-full bg-surface p-8 md:p-16 shadow-[12px_12px_0px_rgba(69,85,101,0.1)] flex flex-col lg:flex-row items-center gap-16"
    >
      <!-- Left Column -->
      <div class="flex flex-col items-start w-full lg:w-[520px] shrink-0">
        <span
          class="font-pixel text-[10px] uppercase text-primary tracking-widest mb-4"
        >
          The Sanctuary
        </span>
        <h2
          class="font-display font-bold text-5xl md:text-[48px] leading-none uppercase tracking-[-2.4px] text-on-surface mb-4"
        >
          Visit The<br />Headquarters
        </h2>

        <div class="flex flex-col gap-8 w-full py-4 mb-8">
          <!-- Item 1 -->
          <div class="flex flex-row items-center gap-6">
            <div
              class="w-12 h-12 bg-surface-container-low flex justify-center items-center shrink-0"
            >
              <MapPin class="text-primary" />
            </div>
            <div class="flex flex-col gap-1">
              <span
                class="font-pixel text-[8px] uppercase text-on-surface-variant tracking-widest"
              >
                Coordinates
              </span>
              <span class="font-display font-bold text-lg text-on-surface">
                128 Pixel Way, Digital District, SF
              </span>
            </div>
          </div>
          <!-- Item 2 -->
          <div class="flex flex-row items-center gap-6">
            <div
              class="w-12 h-12 bg-surface-container-low flex justify-center items-center shrink-0"
            >
              <Phone class="text-primary" />
            </div>
            <div class="flex flex-col gap-1">
              <span
                class="font-pixel text-[8px] uppercase text-on-surface-variant tracking-widest"
              >
                Direct Link
              </span>
              <span class="font-display font-bold text-lg text-on-surface">
                +1 (555) 8-BIT-CAT
              </span>
            </div>
          </div>
          <!-- Item 3 -->
          <div class="flex flex-row items-center gap-6">
            <div
              class="w-12 h-12 bg-surface-container-low flex justify-center items-center shrink-0"
            >
              <Mail class="text-primary" />
            </div>
            <div class="flex flex-col gap-1">
              <span
                class="font-pixel text-[8px] uppercase text-on-surface-variant tracking-widest"
              >
                Data Stream
              </span>
              <span class="font-display font-bold text-lg text-on-surface">
                hello@kitt8bit.com
              </span>
            </div>
          </div>
        </div>

        <Button label="SCHEDULE A VISIT" variant="primary" />
      </div>

      <!-- Right Column -->
      <div
        class="relative w-full max-w-[520px] aspect-square shrink-0 mt-8 lg:mt-0 mx-auto"
      >
        <!-- Badge -->
        <div class="absolute -top-4 -right-4 bg-[#265C54] py-2 px-4 z-20">
          <span
            class="font-pixel text-[8px] uppercase text-white tracking-widest"
          >
            Shelter Cam: Online
          </span>
        </div>

        <!-- Image -->
        <div class="w-full h-full bg-primary-container relative z-10">
          <img
            src="/hero_cat.png"
            alt="Modern cat shelter interior"
            class="w-full h-full object-cover grayscale-20"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

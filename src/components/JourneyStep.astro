---
export interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div
  class="flex flex-col md:flex-row items-start p-8 md:p-10 gap-6 md:gap-8 bg-surface"
>
  <div class="font-pixel text-2xl text-primary opacity-20 w-12 shrink-0 mt-1">
    {number}
  </div>
  <div class="flex flex-col gap-4">
    <h4
      class="font-display font-bold text-2xl uppercase tracking-tight text-on-surface"
    >
      {title}
    </h4>
    <p class="font-body text-base text-on-surface-variant leading-relaxed">
      {description}
    </p>
  </div>
</div>
